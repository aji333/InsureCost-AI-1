{
  "version": 2,
  "builds": [
    {
      "src": "api/predict.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/predict.py"
    },
    {
      "src": "/style.css",
      "dest": "public/style.css"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
